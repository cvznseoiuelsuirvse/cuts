#include <signal.h>
#include <assert.h>

#include "util/list.h"

typedef void (*c_signal_handler)(void *userdata);

struct __signal_handler {
  int signal;
  c_signal_handler handler;
  void *userdata;
};

static int n_signal_handlers = 0;
static struct __signal_handler signal_handlers[64]; // should be enough

static void signal_handler(int signal) {
  if (!signal_handlers) return;

  struct __signal_handler *h;
  c_list_for_each(signal_handlers, h) {
    if (h->signal == signal)
      h->handler(h->userdata);
  }
}

void c_signal_handler_add(int signal, c_signal_handler handler, void *userdata) {
  if (!signal_handlers) 
    signal_handlers = c_list_new();

  struct __signal_handler h = {
    .signal = signal,
    .handler = handler,
    .userdata = userdata,
  };
  c_list_push(signal_handlers, userdata, sizeof(h));

  struct sigaction sa;
  sa.sa_handler = signal_handler;
  sa.sa_flags = 0;
  sigemptyset(&sa.sa_mask);

  assert(sigaction(signal, &sa, NULL) == 0);
}
