#include <linux/vt.h>
#include <sys/ioctl.h>
#include <fcntl.h>
#include <stdint.h>

#include "util/log.h"

int get_active_vt() {
  int fd = open("/dev/tty", O_RDONLY | O_CLOEXEC);
  if (!fd) {
    c_log_errno(C_LOG_ERROR, "failed to open /dev/tty");
    return -1;
  }

  struct vt_stat st;
  if (ioctl(fd, VT_GETSTATE, &st) < 0) {
    c_log_errno(C_LOG_ERROR, "ioctl failed");
    return -1;
  }

  return st.v_active;
}

int open_terminal() {}

int drm_ioctl(int fd, int req) {
  int ret;
  do {
      ret = ioctl(fd, req, NULL);
  } while (ret == -1 && (errno == EINTR || errno == EAGAIN));
  return ret;
}
